# Rust / wasm-pack build output. Cargo target dirs everywhere; `target` may be
# a symlink to a `target.noindex` dir (keeps Spotlight from indexing build output)
**/target
**/target.noindex/
rust/pkg/

# Browser reader: wasm-pack output copied into the demo at deploy time (deploy.sh
# builds it fresh). Not committed — it's a build artifact, not source.
examples/openalex/web/roaringrange.js
examples/openalex/web/roaringrange_bg.wasm

# Go binaries
/openalexbuild
examples/openalex/openalex
*.test

# index / data build artifacts (never commit large generated indexes)
*.rrs
*.rrf
*.ftsr
records.bin
records.idx
*.gz

# local reader perf/test harness (loads a built wasm bundle + a local index)
rust/webtest/

# OS / editor
.DS_Store
*.swp

# local session handoff notes (contains AWS resource IDs; not for the public repo)
.session-notes.md

# local one-off corpus build/ops helpers (resumable Gemma embed, dashboards, uploaders;
# corpus-specific scratch, not part of the library)
python/scripts/embed_gemma_memmap.py
dash.sh
upload_s3.py
resume_multipart.py

# built CLI binary
/roaringrange

# goreleaser build output
/dist/

# task ledger moved to the central taskman store (~/.taskman/roaringrange);
# a repo-local tasks/ must not re-track
/tasks/
