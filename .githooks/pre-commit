#!/bin/sh
# Enforce gofmt + rustfmt on staged changes so the CI formatting checks never
# fail. Enable once per clone:
#
#   git config core.hooksPath .githooks
#
set -e
fail=0

# Go: staged .go files must be gofmt-clean.
gofiles=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [ -n "$gofiles" ]; then
  bad=$(gofmt -l $gofiles || true)
  if [ -n "$bad" ]; then
    echo "✗ gofmt needed:"
    echo "$bad" | sed 's/^/    /'
    echo "  fix: gofmt -w $bad"
    fail=1
  fi
fi

# Rust: if any source under a crate dir is staged, that crate must be
# rustfmt-clean. Mirrors the crates CI and the pre-push hook run
# `cargo fmt --check` on (the old `reader/` path predated the move to `rust/`).
staged_rs=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$' || true)
if [ -n "$staged_rs" ]; then
  for dir in rust examples/openalex/builder; do
    if printf '%s\n' "$staged_rs" | grep -q "^$dir/"; then
      if ! ( cd "$dir" && cargo fmt --check >/dev/null 2>&1 ); then
        echo "✗ rustfmt needed in $dir/  —  fix: (cd $dir && cargo fmt)"
        fail=1
      fi
    fi
  done
fi

[ "$fail" -eq 0 ] || { echo "pre-commit: formatting issues — commit aborted."; exit 1; }
