#!/bin/sh
# Enforce gofmt + rustfmt on staged changes so the CI formatting checks never
# fail. Enable once per clone:
#
#   git config core.hooksPath .githooks
#
set -e
fail=0

# Go: staged .go files must be gofmt-clean.
gofiles=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [ -n "$gofiles" ]; then
  bad=$(gofmt -l $gofiles || true)
  if [ -n "$bad" ]; then
    echo "✗ gofmt needed:"
    echo "$bad" | sed 's/^/    /'
    echo "  fix: gofmt -w $bad"
    fail=1
  fi
fi

# Rust: if any reader source is staged, the crate must be rustfmt-clean.
if git diff --cached --name-only --diff-filter=ACM | grep -q '^reader/.*\.rs$'; then
  if ! ( cd reader && cargo fmt --check >/dev/null 2>&1 ); then
    echo "✗ rustfmt needed in reader/  —  fix: (cd reader && cargo fmt)"
    fail=1
  fi
fi

[ "$fail" -eq 0 ] || { echo "pre-commit: formatting issues — commit aborted."; exit 1; }
