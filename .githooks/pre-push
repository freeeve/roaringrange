#!/bin/sh
# Pre-push: run CI's fmt + lint gates locally so a failure is caught before it
# reaches CI. CI runs `cargo fmt --check` and `cargo clippy --all-targets -- -D
# warnings` on the rust crate and the openalex builder, and `gofmt -s` on the Go
# sources.
#
# Enable once per clone:   git config core.hooksPath .githooks
# Bypass for one push:     git push --no-verify
set -e
repo="$(git rev-parse --show-toplevel)"

for dir in rust examples/openalex/builder; do
	echo "[pre-push] $dir: cargo fmt --check + clippy…"
	(cd "$repo/$dir" && cargo fmt --check && cargo clippy --all-targets -- -D warnings)
done

# The crate's `vector` feature is off by default, so the default clippy above
# does not compile it; lint it explicitly to match CI's vector-feature gate.
echo "[pre-push] rust: cargo clippy --features vector…"
(cd "$repo/rust" && cargo clippy --all-targets --features vector -- -D warnings)

# The `terms` feature (RRTI term index) is also off by default; lint it explicitly.
echo "[pre-push] rust: cargo clippy --features terms…"
(cd "$repo/rust" && cargo clippy --all-targets --features terms -- -D warnings)

# The `hotcache` feature (RRHC catalog hotcache) is also off by default.
echo "[pre-push] rust: cargo clippy --features hotcache…"
(cd "$repo/rust" && cargo clippy --all-targets --features hotcache -- -D warnings)

# The `splits` feature (RRSS split set) is also off by default.
echo "[pre-push] rust: cargo clippy --features splits…"
(cd "$repo/rust" && cargo clippy --all-targets --features splits -- -D warnings)

# The split-set boot bundle exercises `splits` + `hotcache` together (an RRHC over a split set).
echo "[pre-push] rust: cargo clippy --features 'splits hotcache'…"
(cd "$repo/rust" && cargo clippy --all-targets --features "splits hotcache" -- -D warnings)

# The term-bodied split set (RRTI splits) lives under `splits` + `terms` together.
echo "[pre-push] rust: cargo clippy --features 'splits terms'…"
(cd "$repo/rust" && cargo clippy --all-targets --features "splits terms" -- -D warnings)

echo "[pre-push] go: gofmt -s check…"
unformatted="$(cd "$repo" && gofmt -s -l .)"
if [ -n "$unformatted" ]; then
	echo "[pre-push] not gofmt'd: $unformatted (run: gofmt -s -w .)" >&2
	exit 1
fi

echo "[pre-push] fmt + lint gates passed."
