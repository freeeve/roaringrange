#!/bin/sh
# Pre-push: run CI's fmt + lint gates locally so a failure is caught before it
# reaches CI. CI runs `cargo fmt --check` and `cargo clippy --all-targets -- -D
# warnings` on the rust crate and the openalex builder, and `gofmt -s` on the Go
# sources.
#
# Enable once per clone:   git config core.hooksPath .githooks
# Bypass for one push:     git push --no-verify
set -e
repo="$(git rev-parse --show-toplevel)"

for dir in rust examples/openalex/builder; do
	echo "[pre-push] $dir: cargo fmt --check + clippy…"
	(cd "$repo/$dir" && cargo fmt --check && cargo clippy --all-targets -- -D warnings)
done

# The crate's `vector` feature is off by default, so the default clippy above
# does not compile it; lint it explicitly to match CI's vector-feature gate.
echo "[pre-push] rust: cargo clippy --features vector…"
(cd "$repo/rust" && cargo clippy --all-targets --features vector -- -D warnings)

echo "[pre-push] go: gofmt -s check…"
unformatted="$(cd "$repo" && gofmt -s -l .)"
if [ -n "$unformatted" ]; then
	echo "[pre-push] not gofmt'd: $unformatted (run: gofmt -s -w .)" >&2
	exit 1
fi

echo "[pre-push] fmt + lint gates passed."
